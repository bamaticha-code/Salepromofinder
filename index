function categoriesFor(programId, group){
  if(programId==='s_general') return ['always'];
  if(programId==='s_target_general') return ['กลุ่มข้าว/พืชไร่/พืชรวม'];
  if(programId==='s_target_yfsw') return ['YF,SW'];
  if(programId==='s_target_rt') return ['RT'];
  if(programId==='s_bob25'){
    if(group==='General') return ['กลุ่มข้าว/พืชไร่/พืชรวม','กอช./ผู้นำชุมชน/ธกส 3A'];
    if(group==='YF,SW') return ['YF,SW'];
    if(group==='RT') return ['RT'];
  }
  if(programId==='s_bob30') return ['กอช./ผู้นำชุมชน/ธกส 3A'];
  return [];
}
function findEntriesForModelSolis(model){
  const programs = DATA.solis.programs;
  const rows = [];
  programs.forEach(p=>{
    if(p.entries[model]){
      rows.push({program:p, group: p.groups[0]==='ทั่วไป' ? 'ทุกกลุ่ม' : p.groups[0], entry: p.entries[model], variant:null});
      return;
    }
    if(p.models_subset){
      const subsetMatch = p.models_subset.find(sm => sm===model);
      if(subsetMatch){
        p.groups.forEach(g=>{
          const key = `${subsetMatch} | ${g}`;
          if(p.entries[key]) rows.push({program:p, group:g, entry:p.entries[key], variant:null});
        });
      }
    }
  });
  rows.forEach(r=>{ r.categories = categoriesFor(r.program.id, r.group); });
  return rows;
}
function bestRowForCategory(rows, category){
  const matching = rows.filter(r => r.categories.includes('always') || r.categories.includes(category));
  const usable = matching.filter(r=>!r.entry.pending);
  if(usable.length===0) return null;
  const sortKey = r => (r.entry.down||0) - (r.entry.customer_out ?? 0);
  usable.sort((a,b)=> sortKey(b)-sortKey(a) || (b.entry.rst??0)-(a.entry.rst??0));
  return usable[0];
}

// ===== Yanmar segment + toggle logic =====
function findEntriesForModelYanmar(model, segment, toggles){
  const programs = DATA.yanmar.programs;
  const keys = LOOKUP_KEYS[model];
  const rows = [];

  function getDirect(programId){
    const p = programs.find(x=>x.id===programId);
    const key = keys.find(k=>p.entries[k]);
    if(key) rows.push({program:p, group:null, entry:p.entries[key], variant:null});
  }
  function getSubsetGroup(programId, group){
    const p = programs.find(x=>x.id===programId);
    if(!p.models_subset) return;
    const subsetKey = keys.find(k=>p.models_subset.includes(k));
    if(subsetKey){
      const e = p.entries[`${subsetKey} | ${group}`];
      if(e) rows.push({program:p, group, entry:e, variant:null});
    }
  }

  getDirect('y_general');

  if(model==='YM358R'){
    const p358 = programs.find(x=>x.id==='y_358');
    Object.keys(p358.entries).forEach(variant=>{
      rows.push({program:p358, group:null, entry:p358.entries[variant], variant});
    });
  }

  if(segment==='ทั่วไป'){
    if(toggles.land50) getDirect('y_target_general');
    if(toggles.land30) getSubsetGroup('y_bob25','General');
    if(toggles.baac) getSubsetGroup('y_bob30','General');
    getSubsetGroup('y_general30','General');
  } else if(segment==='YF,SW'){
    getDirect('y_target_yfsw');
    getSubsetGroup('y_general30','SW,YF');
    getSubsetGroup('y_bob25','YF,SW');
    if(toggles.baac) getSubsetGroup('y_bob30','YF,SW');
  } else if(segment==='RT'){
    getDirect('y_target_rt');
    getSubsetGroup('y_general30','RT');
    getSubsetGroup('y_bob25','RT');
    if(toggles.baac) getSubsetGroup('y_bob30','RT');
  }
  return rows;
}

